# Scraper Service — variables de entorno
# Copiar a .env y ajustar antes de arrancar

# RabbitMQ
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# MongoDB — almacén de resultados raw
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=pricetracker

# FastAPI admin
API_HOST=0.0.0.0
API_PORT=8001

# HTTP scraping
HTTP_TIMEOUT=30.0
USER_AGENT=PriceTrackerBot/1.0
