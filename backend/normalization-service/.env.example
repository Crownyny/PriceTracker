# Normalizer Service — variables de entorno
# Copiar a .env y ajustar antes de arrancar

# RabbitMQ
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# MongoDB — lectura de resultados raw del Scraper
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=pricetracker

# PostgreSQL — productos normalizados e historial de precios
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pricetracker

# FastAPI admin
API_HOST=0.0.0.0
API_PORT=8002

# Enriquecimiento LLM (desactivado por defecto)
ENABLE_ENRICHER=false
# OPENAI_API_KEY=sk-...

# Archivo de fallos de normalización (JSONL). Línea por fallo, útil para debug.
# Dejar vacío para desactivar el registro en archivo.
FAILURES_LOG_PATH=/tmp/normalization_failures.jsonl
# OPENAI_MODEL=gpt-4o-mini

# Validador semántico (2 capas: dominio + few-shot KB)
ENABLE_SEMANTIC_VALIDATOR=true
SEMANTIC_CONFIG_PATH=app/graph/nodes/semantic_kb.default.json
SEMANTIC_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Umbrales opcionales. Si se omiten, se usan los definidos en SEMANTIC_CONFIG_PATH.
# SEMANTIC_DOMAIN_THRESHOLD=0.08
# SEMANTIC_VALID_THRESHOLD=0.2
# SEMANTIC_INVALID_THRESHOLD=-0.1
SEMANTIC_TOP_K=3
