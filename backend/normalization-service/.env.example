# Normalizer Service — variables de entorno
# Copiar a .env y ajustar antes de arrancar

# RabbitMQ
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# MongoDB — lectura de resultados raw del Scraper
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=pricetracker

# PostgreSQL — productos normalizados e historial de precios
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pricetracker

# FastAPI admin
API_HOST=0.0.0.0
API_PORT=8002

# Enriquecimiento LLM (desactivado por defecto)
ENABLE_ENRICHER=false
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
