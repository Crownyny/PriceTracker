{
  "manifest_version": 3,
  "name": "Price Tracker",
  "version": "1.0.0",
  "description": "Compara precios de productos en tiempo real mientras navegas",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:8443/*",
    "https://localhost:8080/*",
    "https://localhost:8443/*",
    "https://www.google.com/*",
    "https://www.google.com.co/*",
    "https://google.com/*",
    "https://google.com.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' https://www.gstatic.com; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com.co/search*",
        "https://google.com/search*",
        "https://google.com.co/search*"
      ],
      "js": [
        "content/constants.js",
        "content/firebase-config.js",
        "content/state.js",
        "content/state/status-messages.js",
        "content/domain/contracts.js",
        "content/pom/google-search.page.js",
        "content/transport/api-relay.js",
        "content/transport/stomp-relay-client.js",
        "content/services/pricing.service.js",
        "content/services/intent.service.js",
        "content/firebase-auth.service.js",
        "content/application/search-workflow.service.js",
        "content/presentation/search-panel.presenter.js",
        "content/ui/status-indicator.ui.js",
        "content/ui/overlay.ui.js",
        "content/controllers/monitor.controller.js",
        "content/debug/ws-debug.js",
        "content.js"
      ],
      "css": ["content.css", "content/ui/minimized-tab.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": [
        "https://www.google.com/*",
        "https://www.google.com.co/*",
        "https://google.com/*",
        "https://google.com.co/*"
      ]
    }
  ]
}
