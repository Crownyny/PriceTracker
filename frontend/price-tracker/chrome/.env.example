# Template local only. Copy to chrome/.env.local and fill real values.
FIREBASE_API_KEY=your_api_key_here
APP_ENV=development
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:your-app-id
FIREBASE_MEASUREMENT_ID=
DASHBOARD_URL_DEV=http://localhost:4200/dashboard
DASHBOARD_URL_PROD=https://your-domain.com/dashboard